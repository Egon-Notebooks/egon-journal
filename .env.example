# Copy this file to .env and fill in your paths.
# All variables are optional — the CLI falls back to ./generated if unset.

# Directory where journal entry nodes are written (type: journal)
EGON_JOURNAL_DIR=/Users/you/my-egon-graph/journal

# Directory where summary nodes are written (type: summary)
EGON_SUMMARIES_DIR=/Users/you/my-egon-graph/summaries

# Root of your assembled Egon graph (used by 'egon index')
EGON_GRAPH_DIR=/Users/you/my-egon-graph

# Full path to your Apple Health export.xml file.
# Export: Health app → profile picture → Export All Health Data → unzip → export.xml
EGON_APPLE_HEALTH_XML=/Users/you/Downloads/apple_health_export/export.xml

# Target weight goals shown as dotted lines on the weight report (optional).
# Use the same unit as your Apple Health data (kg or lb).
EGON_TARGET_BODY_MASS=your-target-body-mass
EGON_TARGET_LEAN_BODY_MASS=your-target-lean-body-mass
EGON_TARGET_RESTING_HEART_RATE=your-target-lean-body-mass
